# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# For local dev, use: mongodb://localhost:27017/airbnb-clone
# For MongoDB Atlas (production), use your connection string:
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate a secure random secret:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=5b575a78afc53c931abfcd02353dcea8b8605ee34b3218cb68680868b13f31bb

# ─── CORS ──────────────────────────────────────────────────────────────────────
# In production, set this to your Heroku app URL (or custom domain).
# Comma-separated for multiple origins.
# CLIENT_ORIGIN=https://yourapp.herokuapp.com
